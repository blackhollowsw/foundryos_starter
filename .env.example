# ============================================================
# FoundryOS Starter — Environment Variables
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local to git.
# Store all real values in your password manager.
# ============================================================

# ── Database (Neon) ──────────────────────────────────────────
# Found in: Neon console → your project → Connection Details
# Use the POOLED string for DATABASE_URL (production / Vercel).
# Use the DIRECT string for DATABASE_URL_DIRECT (migrations).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_DIRECT="postgresql://user:password@direct-host/dbname?sslmode=require"

# ── Authentication (Clerk) ───────────────────────────────────
# Found in: Clerk Dashboard → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect paths — usually no need to change these
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Email (Resend) ───────────────────────────────────────────
# Found in: Resend dashboard → API Keys
RESEND_API_KEY="re_..."

# The "from" address — must be a verified domain in Resend
ALERT_FROM_EMAIL="alerts@yourdomain.com"

# Alert destination — who receives incident emails
ALERT_TO_EMAIL="you@yourdomain.com"

# ── SMS (Textbelt) ───────────────────────────────────────────
# Found in: https://textbelt.com — purchase a key
# Phone number in E.164 format: +15551234567
TEXTBELT_API_KEY="..."
ALERT_PHONE_NUMBER="+15551234567"

# ── Credential Encryption ────────────────────────────────────
# AES-256-GCM key for encrypting sensitive values stored in the DB.
# Generate: node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('base64'))"
# WARNING: rotating this key makes existing encrypted values unreadable.
CREDENTIAL_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# ── Cron / Internal API Auth ─────────────────────────────────
# Shared Bearer token for cron routes and GitHub Actions.
# Generate: node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('hex'))"
APP_SYNC_SECRET="your-random-hex-secret"

# ── App Identity ─────────────────────────────────────────────
APP_NAME="Your App Name"
APP_URL="https://yourdomain.com"

# ── Vercel (injected automatically — do NOT set manually) ────
# VERCEL_ENV is "production", "preview", or "development"
# Cron routes check this to skip execution on preview deployments.
# VERCEL_ENV=
